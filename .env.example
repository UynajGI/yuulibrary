# 复制为 .env 并填入真实 key（.env 已在 .gitignore，不会进 git）
# GA 环境用同名 GitHub Secret，不读这个文件。
#
# translate_chapters.py / convert_xrefs.py 读取此文件配置。
# cp .env.example .env && 填入你的 key

# LLM provider 选择：deepseek（默认）/ glm / openai
LLM_PROVIDER=deepseek

# ── DeepSeek（platform.deepseek.com 获取）──────────────────
DEEPSEEK_API_KEY=
# DeepSeek 模型，默认 deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-flash
# 可选：自定义 base_url（默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 其他 provider（预留，需要时取消注释）──────────────────
# GLM_API_KEY=
# GLM_MODEL=glm-4-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
