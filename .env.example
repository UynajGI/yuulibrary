# 复制为 .env 并填入真实 key（.env 已在 .gitignore，不会进 git）
# GA 环境用同名 GitHub Secret，不读这个文件。
#
# 翻译流水线 (translate_chapters.py / generate_paper_note.py) 读此文件取 API key。
# 模型名/base_url/pipeline 开关在 config.yaml 配置（随仓库上传，不含密钥）。
# cp .env.example .env && 填入你的 key

# ── DeepSeek（platform.deepseek.com 获取）──────────────────
DEEPSEEK_API_KEY=

# ── 其他 provider（预留，需要时取消注释）──────────────────
# OPENAI_API_KEY=
# GLM_API_KEY=
# MIMO_API_KEY=
