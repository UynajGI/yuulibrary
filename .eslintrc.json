{
  "env": {
    "browser": true,
    "es2020": true
  },
  "globals": {
    "renderMathInElement": "readonly"
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn",
    "no-debugger": "error",
    "no-var": "error",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": { "node": true, "es2020": true },
      "rules": { "no-console": "off" }
    },
    {
      "files": ["static/chat/retrieval.js"],
      "env": { "browser": true, "node": true, "es2020": true }
    }
  ]
}
